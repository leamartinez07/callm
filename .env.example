# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/chatflow?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# Pusher — create a free app at pusher.com/channels
PUSHER_APP_ID=your-app-id
PUSHER_KEY=your-key
PUSHER_SECRET=your-secret
PUSHER_CLUSTER=us2

# Public (exposed to client)
NEXT_PUBLIC_PUSHER_KEY=your-key
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email verification (optional — omit to use console.log in dev)
# Use a Gmail account with an App Password (not your regular password)
# Generate App Password: myaccount.google.com → Security → 2FA → App passwords
EMAIL_USER=you@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Google OAuth (optional — omit to hide the "Continue with Google" button)
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
